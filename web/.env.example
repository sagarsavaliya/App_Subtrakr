# Public (safe to expose to the browser)
NEXT_PUBLIC_SUPABASE_URL=https://supabase.subtrakr.me
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only — NEVER exposed to the browser, NEVER committed.
# On the VPS these live in the deployment .env consumed by docker compose.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# 32-byte hex key for AES-256-GCM encryption of secret app_settings values
# (generate: openssl rand -hex 32). Lives ONLY here — never in DB or git.
SETTINGS_ENCRYPTION_KEY=your-64-char-hex-key
